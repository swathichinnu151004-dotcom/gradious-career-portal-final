# Copy to .env and fill in values. Never commit .env.

# Database (use 127.0.0.1 instead of localhost on Windows to avoid slow IPv6-first resolution)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Primary name for the DB password (preferred)
DB_PASSWORD=
# Alias: same value as DB_PASSWORD if you prefer this name
# DB_PASS=

DB_NAME=gradious_portal
# Optional: max connections in the shared pool (default 20)
# DB_POOL_LIMIT=20

# Auth
JWT_SECRET=

# Google Sign-In (Web client ID)
GOOGLE_CLIENT_ID=

# Where YOU open the React app (Google OAuth, general app origin).
FRONTEND_URL=http://localhost:3000

# Optional — base URL used ONLY in emailed links (recruiter invite, forgot password).
# Leave unset to use FRONTEND_URL. For a course demo to someone else’s phone/laptop on the
# same Wi‑Fi, set this to your PC’s address so the link opens for them, e.g.:
#   EMAIL_LINK_BASE_URL=http://192.168.0.15:3000
# (Find IP with ipconfig / ifconfig; allow ports 3000 and 5000 in Windows Firewall.)
# Tunnel (ngrok, etc.): you may need a tunnel for the API too or use REACT_APP_API_URL on the React build.
# EMAIL_LINK_BASE_URL=

# CORS: required if the React app is on a *different* origin than this API (e.g. Vercel + Railway).
# Comma-separated list. If unset, CORS allows any origin (fine for local dev or same-origin deploys).
# CORS_ORIGINS=https://careers.example.com,https://www.careers.example.com

# Behind a reverse proxy (nginx, Render, Fly, etc.)
# TRUST_PROXY=1

# Bind API to all interfaces (default on servers). Use 127.0.0.1 only if you proxy locally.
# LISTEN_HOST=0.0.0.0

# Optional: built UI folder (defaults to ../career-portal-react/build if it exists)
# STATIC_PATH=

# Server port (default 5000)
# PORT=5000

# Email (SMTP)
EMAIL_USER=
EMAIL_PASS=
MAIL_FROM_DISPLAY=Gradious Careers (Do not reply)

# Optional support address in emails
# SUPPORT_EMAIL=
