# Copy to .env and fill in values. Never commit .env.

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=gradious_portal

# Auth
JWT_SECRET=

# Google Sign-In (Web client ID)
GOOGLE_CLIENT_ID=

# Public URL of the React app (password reset & invite links)
FRONTEND_URL=http://localhost:3000

# Optional: built UI folder (defaults to ../career-portal-react/build if it exists)
# STATIC_PATH=

# Server port (default 5000)
# PORT=5000

# Email (SMTP)
EMAIL_USER=
EMAIL_PASS=
MAIL_FROM_DISPLAY=Gradious Careers (Do not reply)

# Optional support address in emails
# SUPPORT_EMAIL=
