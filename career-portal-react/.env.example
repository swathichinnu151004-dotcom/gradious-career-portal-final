# Optional: if set, the React app uses this client id directly instead of fetching from the API.
# REACT_APP_GOOGLE_CLIENT_ID=

# Optional API base (must end with /api, no trailing slash after "api").
# Public / split hosting: set at *build* time to your API’s public URL, e.g.
# REACT_APP_API_URL=https://api.careers.example.com/api
# Same-origin (UI + API on one domain): leave unset so the app uses the page’s host + /api.
# Local dev: http://localhost:5000/api — LAN access rewrites localhost to the page hostname.
# REACT_APP_API_URL=http://localhost:5000/api

# If CRA "Invalid Host header" appears when using your LAN IP, add to .env.development.local:
# DANGEROUSLY_DISABLE_HOST_CHECK=true
# (Only needed when package.json has a "proxy" field — host check is then stricter.)
